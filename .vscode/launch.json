{
   // Use IntelliSense to find out which attributes exist for C# debugging
   // Use hover for the description of the existing attributes
   // For further information visit https://github.com/OmniSharp/omnisharp-vscode/blob/master/debugger-launchjson.md
   "version": "0.2.0",
   "configurations": [
        {
            "name": "Run Local Publish",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "local publish",
            "program": "${workspaceFolder}/artifacts/publish/Microsoft.SqlTools.ServiceLayer/default/net10.0/MicrosoftSqlToolsServiceLayer.dll",
            "windows": {
                "program": "${workspaceFolder}/artifacts/publish/Microsoft.SqlTools.ServiceLayer/default/net10.0/MicrosoftSqlToolsServiceLayer.exe"
            },
            "args": [],
            "cwd": "${workspaceFolder}/artifacts/publish/Microsoft.SqlTools.ServiceLayer/default/net10.0",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "requireExactSource": false,
            "justMyCode": false,
            "enableStepFiltering": false
        }
    ]
}
