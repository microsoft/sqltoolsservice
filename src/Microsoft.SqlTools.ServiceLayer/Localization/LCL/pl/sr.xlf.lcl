      <Item ItemId=";warning_openConnectionsMustBeClosed" ItemType="0" PsrId="308" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[To change the database properties, SQL Server must close all other connections to the database. Are you sure you want to change the properties and close all other connections?]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Aby zmienić właściwości bazy danych, program SQL Server musi zamknąć wszystkie inne połączenia z bazą danych. Czy na pewno chcesz zmienić właściwości i zamknąć wszystkie inne połączenia?]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
