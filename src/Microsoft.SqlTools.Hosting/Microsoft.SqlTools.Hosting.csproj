<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Nullable>disable</Nullable>
		<EnableDefaultItems>false</EnableDefaultItems>
		<EnableDefaultCompileItems>false</EnableDefaultCompileItems>
		<EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
		<EmbeddedResourceUseDependentUponConvention>false</EmbeddedResourceUseDependentUponConvention>
		<EnableDefaultNoneItems>false</EnableDefaultNoneItems>
		<DefineConstants>$(DefineConstants);NETCOREAPP1_0;TRACE</DefineConstants>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<PreserveCompilationContext>true</PreserveCompilationContext>
		<AssemblyTitle>SqlTools Hosting Library</AssemblyTitle>
		<Description>Provides hosting services for SqlTools applications.</Description>
		<TargetFrameworks>$(SqlToolsServiceDotNetVersion);$(SsmsDotNetVersion);netstandard2.0</TargetFrameworks>
		<LangVersion>8.0</LangVersion>
		<!-- CS8632: Project opts out of nullable analysis via <Nullable>disable</Nullable>; ? annotations in files are informational only -->
		<NoWarn>$(NoWarn);CS8632</NoWarn>
		<DelaySign>True</DelaySign>
		<AssemblyOriginatorKeyFile>$(RootDir)\SQL2003.snk</AssemblyOriginatorKeyFile>
		<SignAssembly Condition="'$(TargetFramework)' == '$(SsmsDotNetVersion)'">True</SignAssembly>
	</PropertyGroup>
	<ItemGroup>
		<Compile Include="**/*.cs" Exclude="**/obj/**/*.cs" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.DependencyModel" />
		<PackageReference Include="Newtonsoft.Json" />
		<PackageReference Include="System.Composition" />
		<PackageReference Include="System.Runtime.Caching" />
		<PackageReference Include="System.Runtime.Loader" />
		<PackageReference Include="System.Text.Encodings.Web" />
		<PackageReference Include="System.Text.Json" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' == '$(SsmsDotNetVersion)'">
		<PackageReference Update="Microsoft.Extensions.DependencyModel" VersionOverride="$(SsmsSystemNugetVersion)" />
		<PackageReference Update="System.Text.Json" VersionOverride="$(SsmsSystemNugetVersion)" />
	</ItemGroup>
	<ItemGroup Condition="'$(TargetFramework)' != '$(SsmsDotNetVersion)'">
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.UnitTests" />
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.IntegrationTests" />
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.Test.Common" />
	</ItemGroup>
	<!-- InternalsVisibleTo for .NET Framework 4.7.2 must include a strong name key since we're signing the assembly when targeting this framework -->
	<ItemGroup Condition="'$(TargetFramework)' == '$(SsmsDotNetVersion)'">
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.UnitTests" Key="" />
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.IntegrationTests" Key="" />
		<InternalsVisibleTo Include="Microsoft.SqlTools.ServiceLayer.Test.Common" Key="" />
	</ItemGroup>
	<ItemGroup>
		<EmbeddedResource Include="Localization\*.resx" />
		<None Include="Localization\sr.strings" />
	</ItemGroup>
</Project>